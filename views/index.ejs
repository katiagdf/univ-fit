    // Charge la séance suggérée à l'utilisateur
    async function loadRecommendedSession() {
        const goal  = USER_GOAL  || 'remise_en_forme';
        const level = USER_LEVEL || 'debutant';
        const seance = SEANCES[goal]?.[level] || SEANCES.remise_en_forme.debutant;

        // Demande confirmation si l'utilisateur a déjà des exercices en cours
        if (exercises.length > 0) {
            if (!confirm(`Remplacer la séance en cours par ta séance recommandée (${seance.length} exercices) ?`)) return;
            // Supprimer les exercices actuels de la base de données
            await Promise.all(exercises.map(e => fetch('/taches/' + e._id, { method:'DELETE' })));
        }

        // Ajoute tous les exercices de la séance recommandée
        const btn = document.querySelector('button[onclick="loadRecommendedSession()"]');
        if (btn) { btn.disabled = true; btn.innerHTML = '<i class="ph ph-spinner animate-spin"></i> Chargement...'; }

        await Promise.all(seance.map(ex =>
            fetch('/taches', {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({
                    name: ex.name,
                    category: ex.category,
                    sets: ex.sets.map(s => ({ ...s, done: false }))
                })
            })
        ));

        await fetchExercises();
        if (btn) { btn.disabled = false; btn.innerHTML = 'Ma séance'; }
    }

  
    // APPELS API 
    
    
    // Récupérer les exercices et l'historique depuis le backend
    async function fetchExercises() {
        try {
            const res  = await fetch('/taches');
            if (!res.ok) throw new Error(res.status);
            const data = await res.json();
            exercises = data.taches || [];
            perfData  = data.performance || [];
            renderExercises();
            renderChart(exercises, perfData);
            updateChartExoSelect();
        } catch(e) {
            console.error(e);
            document.getElementById('exerciseList').innerHTML =
                `<div class="flex items-center justify-center py-10 text-red-400 gap-2 text-sm"><i class="ph ph-warning text-xl"></i> Erreur de chargement</div>`;
        }
    }

    // Ajouter un nouvel exercice manuellement
    async function addExercise() {
        const sel = document.getElementById('exoSelect');
        if (!sel.value) { sel.focus(); return; }
        const [name, category] = sel.value.split('|');
        // Structure standard de 4 séries par défaut
        const sets = [{weight:0,reps:10,done:false},{weight:0,reps:10,done:false},{weight:0,reps:10,done:false},{weight:0,reps:10,done:false}];
        
        try {
            const res = await fetch('/taches', {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ name, category, sets })
            });
            if (!res.ok) throw new Error(res.status);
            sel.value = '';
            fetchExercises();
        } catch(e) { console.error(e); alert('Erreur lors de l\'ajout.'); }
    }


    // MISE À JOUR DE L'INTERFACE UTILISATEUR (UI)


    // Actualiser la barre de progression globale
    function updateProgress() {
        const allSets  = exercises.flatMap(e => e.sets || []);
        const doneSets = allSets.filter(s => s.done).length;
        const pct = allSets.length ? Math.round(doneSets / allSets.length * 100) : 0;
        document.getElementById('progressBar').style.width = pct + '%';
        document.getElementById('progressText').textContent = doneSets + ' / ' + allSets.length + ' séries';
    }

    // Générer et afficher les cartes d'exercices
    function renderExercises() {
        const list = document.getElementById('exerciseList');
        updateProgress();
        if (!exercises.length) {
            list.innerHTML = `<div class="flex flex-col items-center py-12 text-slate-600 gap-2">
                <i class="ph-fill ph-barbell text-5xl"></i>
                <p class="text-sm">Sélectionne un exercice pour commencer</p></div>`;
            return;
        }
        list.innerHTML = '';
        exercises.forEach(ex => {
            const card = document.createElement('div');
            card.className = 'exo-card rounded-2xl p-4 fade-in';
            const allDone = ex.sets.every(s => s.done);
            const cc = catColor[ex.category] || catColor.autre;

            // Calculer le record personnel (PR)
            const exoPerf = perfData.filter(p => p.name === ex.name);
            const maxPR   = exoPerf.length ? Math.max(...exoPerf.map(p => p.weight || 0)) : null;

            card.innerHTML = `
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2 flex-1 min-w-0">
                        <span class="font-bold text-sm text-slate-100 truncate">${ex.name}</span>
                        <span class="cat-badge ${cc} hidden sm:inline">${ex.category}</span>
                        ${maxPR ? `<span class="text-[10px] text-yellow-400 font-bold mono ml-1">PR ${maxPR}kg</span>` : ''}
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0">
                        <button onclick="addSet('${ex._id}')" class="text-[10px] text-cyan-400 hover:text-cyan-300 font-bold flex items-center gap-1 transition-all">
                            <i class="ph ph-plus text-xs"></i> Série
                        </button>
                        <button onclick="deleteExercise('${ex._id}')" class="w-7 h-7 flex items-center justify-center rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-400/10 transition-all">
                            <i class="ph ph-trash text-sm"></i>
                        </button>
                    </div>
                </div>

                <div class="rounded-xl overflow-hidden border border-slate-700/30">
                    <div class="grid grid-cols-[32px_1fr_1fr_1fr_36px] gap-2 px-3 py-1.5 bg-slate-800/50">
                        <span class="text-[10px] text-slate-500 mono font-bold text-center">#</span>
                        <span class="text-[10px] text-slate-500 mono font-bold text-center">KG</span>
                        <span class="text-[10px] text-slate-500 mono font-bold text-center">REPS</span>
                        <span class="text-[10px] text-slate-500 mono font-bold text-center">VOL</span>
                        <span></span>
                    </div>
                    <div id="sets-${ex._id}" class="divide-y divide-slate-700/20">
                        ${renderSetsHTML(ex)}
                    </div>
                </div>

                ${allDone && ex.sets.length ? `
                <div class="mt-2 flex items-center gap-2 text-xs text-cyan-400 font-bold">
                    <i class="ph-fill ph-check-circle"></i>
                    Terminé · ${ex.sets.reduce((s,r)=>s+r.reps,0)} reps · ${ex.sets.reduce((s,r)=>s+(r.weight*r.reps),0)} kg volume
                </div>` : ''}
            `;
            list.appendChild(card);
        });
    }

    // Créer le HTML spécifique pour les lignes de chaque série (sets)
    function renderSetsHTML(ex) {
        return (ex.sets || []).map((s, i) => `
            <div class="set-row ${s.done ? 'set-done' : ''} grid grid-cols-[32px_1fr_1fr_1fr_36px] gap-2 px-3 py-2 items-center" id="setrow-${ex._id}-${i}">
                <span class="text-[11px] text-slate-500 mono font-bold text-center">${i+1}</span>
                <input type="number" min="0" step="2.5" value="${s.weight||0}"
                    class="set-input w-full py-1.5 text-sm"
                    onchange="updateSet('${ex._id}',${i},'weight',this.value)"
                    placeholder="0">
                <input type="number" min="1" value="${s.reps||10}"
                    class="set-input w-full py-1.5 text-sm"
                    onchange="updateSet('${ex._id}',${i},'reps',this.value)"
                    placeholder="10">
                <span class="text-[11px] text-slate-400 mono text-center font-bold" id="vol-${ex._id}-${i}">
                    ${s.weight && s.reps ? Math.round(s.weight * s.reps) + ' kg' : '—'}
                </span>
                <button onclick="toggleSet('${ex._id}',${i})"
                    class="w-7 h-7 flex items-center justify-center rounded-lg transition-all ${s.done ? 'text-cyan-400 bg-cyan-400/15' : 'text-slate-600 hover:text-cyan-400'}">
                    <i class="${s.done ? 'ph-fill ph-check-circle' : 'ph ph-circle'} text-lg"></i>
                </button>
            </div>
        `).join('');
    }

   
    // ÉTAPE 3.5 : INTERACTIONS AVEC LES SÉRIES (SETS)
   

    // Met à jour un champ (poids ou reps) sans sauvegarder immédiatement, affiche juste le volume actualisé
    function updateSet(exId, setIdx, field, value) {
        const ex = exercises.find(e => e._id === exId);
        if (!ex) return;
        ex.sets[setIdx][field] = parseFloat(value) || 0;
        const s = ex.sets[setIdx];
        const volEl = document.getElementById('vol-' + exId + '-' + setIdx);
        if (volEl) volEl.textContent = s.weight && s.reps ? Math.round(s.weight * s.reps) + ' kg' : '—';
    }

    // Valider ou annuler une série (enregistre en base de données)
    async function toggleSet(exId, setIdx) {
        const ex = exercises.find(e => e._id === exId);
        if (!ex) return;
        ex.sets[setIdx].done = !ex.sets[setIdx].done;
        try {
            const res = await fetch('/taches/' + exId, {
                method:'PUT', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ sets: ex.sets })
            });
            if (!res.ok) throw new Error(res.status);
            const updated = await res.json();
            const idx = exercises.findIndex(e => e._id === exId);
            exercises[idx] = updated;
            perfData = (await (await fetch('/taches')).json()).performance || perfData;
            renderExercises();
            renderChart(exercises, perfData);
        } catch(e) { console.error(e); }
    }

    // Ajouter une nouvelle ligne de série à l'exercice
    async function addSet(exId) {
        const ex = exercises.find(e => e._id === exId);
        if (!ex) return;
        
        // Copie les infos de la dernière série comme point de départ
        const last = ex.sets[ex.sets.length - 1] || { weight:0, reps:10 };
        ex.sets.push({ weight: last.weight, reps: last.reps, done: false });
        
        try {
            await fetch('/taches/' + exId, {
                method:'PUT', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ sets: ex.sets })
            });
            fetchExercises();
        } catch(e) { console.error(e); }
    }

    // Supprimer un exercice complètement
    window.deleteExercise = async (id) => {
        if (!confirm('Supprimer cet exercice ?')) return;
        await fetch('/taches/' + id, { method:'DELETE' });
        fetchExercises();
    };

    
    //  GRAPHIQUE D'ÉVOLUTION (CHART.JS)
    

    // Actualiser le sélecteur d'exercices avec ceux possédant un historique
    function updateChartExoSelect() {
        const sel  = document.getElementById('chartExoSelect');
        const prev = sel.value;
        const names = [...new Set(perfData.map(p => p.name))].sort();

        sel.innerHTML = '<option value="">— Choisir un exercice à analyser —</option>' +
            names.map(n => `<option value="${n}" ${n===prev?'selected':''}>${n}</option>`).join('');

        // Sélection automatique du premier s'il y en a un
        if (!prev && names.length) sel.value = names[0];
    }

    // Regrouper l'historique de performance par jour pour tracer les points
    function groupPerfBySession(name) {
        const entries = perfData.filter(p => p.name === name);
        const byDay   = {};
        entries.forEach(p => {
            const key = new Date(p.date).toDateString();
            if (!byDay[key]) byDay[key] = { date: new Date(p.date), weights: [], reps: [] };
            byDay[key].weights.push(p.weight || 0);
            byDay[key].reps.push(p.reps || 0);
        });
        
        return Object.values(byDay)
            .sort((a,b) => a.date - b.date)
            .map(d => ({
                date:      d.date,
                label:     d.date.toLocaleDateString('fr-FR', { day:'2-digit', month:'short' }),
                maxWeight: Math.max(...d.weights),
                totalReps: d.reps.reduce((a,b)=>a+b, 0),
                tonnage:   d.weights.reduce((s,w,i) => s + w * d.reps[i], 0)
            }));
    }

    // Dessiner et mettre à jour le graphique
    function renderChart(exs, perf) {
        const name = document.getElementById('chartExoSelect')?.value || '';
        const hint = document.getElementById('chartHint');

        // S'il n'y a pas d'exercice sélectionné, cacher le graphique
        if (!name) {
            hint.style.display = 'block';
            if (myChart) { myChart.destroy(); myChart = null; }
            document.getElementById('kpiPR').textContent   = '—';
            document.getElementById('kpiLast').textContent = '—';
            document.getElementById('kpiTrend').textContent= '—';
            return;
        }
        hint.style.display = 'none';

        const sessions = groupPerfBySession(name);

        // Injecter en temps réel les données du jour si l'exercice est en cours
        const todayStr = new Date().toDateString();
        const curSets  = exs.filter(e => e.name === name).flatMap(e => (e.sets||[]).filter(s=>s.done));
        const alreadyToday = sessions.length && sessions[sessions.length-1].date.toDateString() === todayStr;
        
        if (curSets.length && !alreadyToday) {
            sessions.push({
                date:      new Date(),
                label:     "Auj.",
                maxWeight: Math.max(...curSets.map(s=>s.weight||0)),
                totalReps: curSets.reduce((a,s)=>a+(s.reps||0),0),
                tonnage:   curSets.reduce((a,s)=>a+(s.weight||0)*(s.reps||0),0)
            });
        }

        // Limiter aux 8 dernières séances pour la lisibilité
        const display = sessions.slice(-8);
        const labels  = display.map(s => s.label);

        // Préparer les données en fonction de l'onglet actif
        const metricMap = {
            maxweight: { data: display.map(s=>s.maxWeight), unit:'kg',   color:['#06b6d4','rgba(6,182,212,0.15)'] },
            volume:    { data: display.map(s=>s.totalReps), unit:'reps', color:['#a855f7','rgba(168,85,247,0.15)'] },
            tonnage:   { data: display.map(s=>Math.round(s.tonnage)), unit:'kg', color:['#f59e0b','rgba(245,158,11,0.15)'] }
        };
        const m = metricMap[currentTab] || metricMap.maxweight;

        // Mise à jour des petits indicateurs sous le graphique (PR, Dernière perf, etc.)
        const pr   = sessions.length ? Math.max(...sessions.map(s=>s.maxWeight)) : null;
        const last = display.length  ? m.data[m.data.length-1] : null;
        const prev = display.length > 1 ? m.data[m.data.length-2] : null;
        const trend = last === null ? '—' : prev === null ? '→' : last > prev ? '↑' : last < prev ? '↓' : '→';
        const tc    = trend==='↑' ? 'text-emerald-400' : trend==='↓' ? 'text-red-400' : 'text-slate-400';

        document.getElementById('kpiPR').textContent    = pr   !== null ? pr   + ' kg' : '—';
        document.getElementById('kpiLast').textContent  = last !== null ? last + ' ' + m.unit : '—';
        document.getElementById('kpiTrend').textContent = trend;
        document.getElementById('kpiTrend').className   = 'text-sm font-black ' + tc;

        // Configuration du style des points (Met en valeur le PR)
        const prVal   = Math.max(...m.data);
        const ptColors = m.data.map((v,i) => i === m.data.length-1 ? m.color[0] : m.color[1].replace('0.15','0.5'));
        const ptRadius = m.data.map(v => v === prVal ? 6 : 3);

        // Mise à jour de l'instance du graphique si elle existe déjà
        if (myChart) {
            myChart.data.labels                          = labels;
            myChart.data.datasets[0].data               = m.data;
            myChart.data.datasets[0].borderColor         = m.color[0];
            myChart.data.datasets[0].pointBackgroundColor= ptColors;
            myChart.data.datasets[0].pointRadius         = ptRadius;
            myChart.data.datasets[0].backgroundColor     = m.color[1];
            myChart.update();
            return;
        }

        // Sinon on crée un nouveau graphique Chart.js
        const ctx = document.getElementById('evolutionChart').getContext('2d');
        myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    data: m.data,
                    borderColor: m.color[0],
                    backgroundColor: m.color[1],
                    borderWidth: 2.5,
                    tension: 0.35,
                    fill: true,
                    pointBackgroundColor: ptColors,
                    pointBorderColor:     m.color[0],
                    pointRadius:          ptRadius,
                    pointHoverRadius:     7
                }]
            },
            options: {
                responsive:true, maintainAspectRatio:false,
                plugins: {
                    legend: { display:false },
                    tooltip: {
                        backgroundColor:'rgba(7,13,26,0.95)',
                        borderColor:'rgba(71,85,105,0.3)', borderWidth:1,
                        titleColor:'#e2e8f0', bodyColor:'#94a3b8', padding:10,
                        callbacks: {
                            title: items => display[items[0].dataIndex]?.date
                                .toLocaleDateString('fr-FR',{weekday:'short',day:'numeric',month:'short'}) || '',
                            label: ctx => ' ' + ctx.raw + ' ' + m.unit +
                                (ctx.raw === prVal ? '  🏆 PR' : '')
                        }
                    }
                },
                scales: {
                    x: { grid:{display:false}, ticks:{color:'#475569', font:{size:10, family:'Space Mono'}} },
                    y: {
                        grid:{color:'rgba(71,85,105,0.1)'},
                        ticks:{color:'#475569', font:{size:9}, maxTicksLimit:4},
                        beginAtZero:false,
                        suggestedMin: m.data.length ? Math.min(...m.data) * 0.9 : 0
                    }
                }
            }
        });
    }

    // Gère le changement d'onglet (Poids Max, Volume, Tonnage)
    window.switchChart = function(tab) {
        currentTab = tab;
        ['maxweight','volume','tonnage'].forEach(t => {
            const btn = document.getElementById('tab-'+t);
            if (!btn) return;
            btn.className = 'chart-tab ' + (t===tab ? 'active font-bold' : '') + ' px-2 py-1 text-[10px]';
        });
        if (myChart) { myChart.destroy(); myChart = null; }
        renderChart(exercises, perfData);
    };

    
    // CHAT EN TEMPS RÉEL (SOCKET.IO)
   
    try {
        const socket      = io();
        const chatMessages = document.getElementById('chatMessages');
        const chatInput    = document.getElementById('chatInput');

        // Charger l'historique des messages à la connexion
        socket.on('load messages', (messages) => {
            messages.forEach(msg => appendMessage(msg.user, msg.text, false));
        });

        // Recevoir un message en temps réel depuis un autre utilisateur
        socket.on('chat message', (msg) => {
            appendMessage(msg.user, msg.text, msg.id === socket.id);
        });

        // Fonction pour injecter le message dans la fenêtre de chat
        function appendMessage(user, text, isMe) {
            const div = document.createElement('div');
            div.className = 'flex gap-2 ' + (isMe ? 'flex-row-reverse' : '') + ' fade-in';
            div.innerHTML = `
                <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-[9px] font-black ${isMe ? 'bg-cyan-500 text-slate-900' : 'bg-red-500 text-white'}">
                    ${(user||'BRO').substring(0,3).toUpperCase()}
                </div>
                <div class="${isMe ? 'bg-cyan-500/10 border-cyan-500/20 rounded-tr-sm' : 'bg-slate-700/40 border-slate-600/40 rounded-tl-sm'} border rounded-xl px-3 py-2 max-w-[80%] leading-relaxed">
                    ${text}
                </div>`;
            chatMessages.appendChild(div);
            // Toujours scroller tout en bas
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // Envoyer le message
        document.getElementById('chatForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const val = chatInput.value.trim();
            if (val) {
                socket.emit('chat message', { user: USERNAME, text: val });
                chatInput.value = '';
            }
        });
    } catch(e) { console.warn('Socket.io non disponible pour le chat'); }

  
    // LANCEMENT DES FONCTIONNALITÉS
   
    fetchExercises();
    </script>
</body>
</html>