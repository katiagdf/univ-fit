<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Univ-FIT | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .mono { font-family: 'Space Mono', monospace; }
        .glass { background:rgba(15,23,42,0.7); backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,0.07); }
        .glass-dark { background:rgba(7,13,26,0.85); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.05); }

        .fade-in { animation:fadeIn 0.35s ease forwards; opacity:0; }
        @keyframes fadeIn { to { opacity:1; } }

        /* Carte exercice */
        .exo-card { background:rgba(17,25,45,0.8); border:1px solid rgba(71,85,105,0.3); transition:border-color 0.2s; }
        .exo-card:has(.set-row.done-all) { border-color:rgba(6,182,212,0.3); }

        /* Ligne de set */
        .set-row { background:rgba(30,41,59,0.5); border:1px solid rgba(71,85,105,0.2); transition:all 0.2s; }
        .set-row.set-done { background:rgba(6,182,212,0.08); border-color:rgba(6,182,212,0.25); }

        /* Input tableau */
        .set-input { background:rgba(15,23,42,0.6); border:1px solid rgba(71,85,105,0.3); color:#e2e8f0;
            text-align:center; border-radius:8px; transition:all 0.2s; font-family:'Space Mono',monospace; }
        .set-input:focus { outline:none; border-color:rgba(6,182,212,0.6); background:rgba(15,23,42,0.9); }
        .set-input::-webkit-inner-spin-button { -webkit-appearance:none; }

        /* Select exercice */
        .exo-select { background:rgba(15,23,42,0.8); border:1px solid rgba(71,85,105,0.4);
            color:#e2e8f0; border-radius:10px; outline:none; cursor:pointer; }
        .exo-select:focus { border-color:rgba(6,182,212,0.6); }
        .exo-select option, .exo-select optgroup { background:#0f172a; color:#e2e8f0; }

        /* Graphique onglets */
        .chart-tab { transition:all 0.2s; border-radius:6px; }
        .chart-tab.active { background:rgba(6,182,212,1); color:#0f172a; font-weight:800; }
        .chart-tab:not(.active) { color:#64748b; }
        .chart-tab:not(.active):hover { color:#94a3b8; }

        .main-grid { display:grid; grid-template-columns:1fr 370px; gap:20px; height:100%; }
        @media(max-width:1024px){ .main-grid { grid-template-columns:1fr; } }

        ::-webkit-scrollbar { width:4px; }
        ::-webkit-scrollbar-thumb { background:rgba(6,182,212,0.2); border-radius:4px; }

        /* Badge catégorie */
        .cat-badge { font-size:10px; font-weight:700; padding:2px 8px; border-radius:5px;
            border:1px solid; text-transform:uppercase; letter-spacing:0.05em; }
    </style>
</head>
<body class="bg-[#070d1a] text-slate-200 min-h-screen">
    <div class="fixed top-[-20%] left-[-10%] w-[40%] h-[50%] bg-blue-600/10 rounded-full blur-[130px] pointer-events-none"></div>
    <div class="fixed bottom-[-10%] right-[-5%] w-[30%] h-[40%] bg-red-600/8 rounded-full blur-[120px] pointer-events-none"></div>

    <header class="flex justify-between items-center px-6 py-4 z-10 border-b border-slate-700/30 glass-dark sticky top-0">
        <div class="flex items-center gap-3">
            <img src="/images/logo66.png" alt="Logo UNIV-FIT" class="logo-glow cursor-pointer" style="height:50px;">
        </div>

        <div class="hidden md:flex items-center gap-5">
            <div class="text-center"><p class="text-[10px] text-slate-500 mono">STREAK</p><p class="text-lg font-black text-cyan-400"><%= user.stats.streak %> 🔥</p></div>
            <div class="w-px h-7 bg-slate-700/50"></div>
            <div class="text-center"><p class="text-[10px] text-slate-500 mono">SÉANCES</p><p class="text-lg font-black text-blue-400"><%= user.stats.totalSessions %></p></div>
        </div>

        <div class="flex items-center gap-3">
            <%
            const levelLabels = { debutant:'Débutant 🌱', intermediaire:'Inter. ⚡', avance:'Athlète 🏆' };
            const goalLabels  = { prise_de_masse:'💪 Masse', perte_de_poids:'🔥 Poids', force:'🏋️ Force', endurance:'🏃 Endurance', remise_en_forme:'✨ Forme' };
            %>
            <div class="hidden md:block text-right">
                <p class="text-sm font-bold"><%= user.username %></p>
                <p class="text-xs text-cyan-400 mono"><%= levelLabels[user.profile.level] %></p>
            </div>
            <a href="/profile" class="relative group">
                <img src="<%= user.avatar || 'https://api.dicebear.com/7.x/shapes/svg?seed=' + user.username %>"
                    class="w-9 h-9 rounded-full border-2 border-cyan-500/40 bg-slate-800 object-cover group-hover:border-cyan-400 transition-all">
                <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-emerald-400 rounded-full border-2 border-[#070d1a]"></div>
            </a>
            <a href="/auth/logout" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-800/50 text-slate-400 hover:text-red-400 hover:bg-red-500/10 transition-all">
                <i class="ph ph-sign-out"></i>
            </a>
        </div>
    </header>

    <main class="p-5 z-10">
        <div class="main-grid max-w-7xl mx-auto">

            <div class="flex flex-col gap-4">

                <%
                const goalConfig = {
                    prise_de_masse:  { emoji:'💪', col:'border-l-cyan-500',    title:'Prise de Masse',   text:'Mouvements composés lourds, 6–12 reps, surplus calorique +300 kcal.', tips:[{l:'6–12 reps',c:'text-cyan-400 bg-cyan-400/10 border-cyan-400/20'},{l:'90s repos',c:'text-blue-400 bg-blue-400/10 border-blue-400/20'},{l:'Surcharge progressive',c:'text-purple-400 bg-purple-400/10 border-purple-400/20'}] },
                    perte_de_poids:  { emoji:'🔥', col:'border-l-orange-500',  title:'Perte de Poids',   text:'Circuit training, 15–20 reps, cardio HIIT post-séance, déficit -400 kcal.', tips:[{l:'15–20 reps',c:'text-orange-400 bg-orange-400/10 border-orange-400/20'},{l:'30s repos',c:'text-red-400 bg-red-400/10 border-red-400/20'},{l:'HIIT cardio',c:'text-yellow-400 bg-yellow-400/10 border-yellow-400/20'}] },
                    force:           { emoji:'🏋️', col:'border-l-purple-500',  title:'Force',            text:'Squat / Bench / Deadlift à 80–90% du 1RM, 1–5 reps, 3–5 min repos.', tips:[{l:'1–5 reps',c:'text-purple-400 bg-purple-400/10 border-purple-400/20'},{l:'3–5 min repos',c:'text-blue-400 bg-blue-400/10 border-blue-400/20'},{l:'80–90% 1RM',c:'text-pink-400 bg-pink-400/10 border-pink-400/20'}] },
                    endurance:       { emoji:'🏃', col:'border-l-green-500',   title:'Endurance',        text:'Circuit training, 20+ reps légers, alternance muscu/cardio continu.', tips:[{l:'20+ reps',c:'text-green-400 bg-green-400/10 border-green-400/20'},{l:'Circuit',c:'text-teal-400 bg-teal-400/10 border-teal-400/20'},{l:'Cardio intensif',c:'text-cyan-400 bg-cyan-400/10 border-cyan-400/20'}] },
                    remise_en_forme: { emoji:'✨', col:'border-l-emerald-500', title:'Remise en Forme',  text:'3 séances/sem, technique avant la charge, régularité sur 3 mois.', tips:[{l:'10–15 reps',c:'text-emerald-400 bg-emerald-400/10 border-emerald-400/20'},{l:'Technique',c:'text-blue-400 bg-blue-400/10 border-blue-400/20'},{l:'Régularité',c:'text-yellow-400 bg-yellow-400/10 border-yellow-400/20'}] }
                };
                const levelPfx = { debutant:'En tant que débutant, ', intermediaire:'', avance:'À ton niveau avancé, ' };
                const cfg = goalConfig[user.profile.goal] || goalConfig.remise_en_forme;
                %>
                <div class="glass rounded-2xl p-4 border-l-4 <%= cfg.col %> flex-shrink-0">
                    <div class="flex justify-between gap-4">
                        <div class="flex-1 min-w-0">
                            <p class="text-[10px] mono uppercase tracking-widest text-slate-500 mb-0.5">Analyse · <%= user.username %></p>
                            <p class="font-bold text-sm text-slate-100"><%= cfg.emoji %> Programme <%= cfg.title %></p>
                            <p class="text-xs text-slate-400 mt-1 leading-relaxed"><%= levelPfx[user.profile.level] %><%= cfg.text %></p>
                            <% if(user.profile.injuries){ %><p class="text-xs text-amber-400 mt-1">⚠️ <%= user.profile.injuries %></p><% } %>
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-2 mt-3 pt-3 border-t border-slate-700/40">
                        <% cfg.tips.forEach(t=>{ %><span class="cat-badge <%= t.c %>"><%= t.l %></span><% }) %>
                        <span class="cat-badge text-slate-400 bg-slate-700/40 border-slate-600/30"><%= user.profile.sessionsPerWeek %>× / sem</span>
                    </div>
                </div>

                <div class="glass rounded-xl px-4 py-3 flex items-center gap-3 flex-shrink-0">
                    <i class="ph ph-magnifying-glass text-slate-500 flex-shrink-0"></i>
                    <select id="exoSelect" class="exo-select flex-1 py-2 px-3 text-sm">
                        <option value="">— Choisir un exercice —</option>
                        
                        <optgroup label="Poitrine">
                            <option value="Développé couché|poitrine">Développé couché</option>
                            <option value="Développé incliné|poitrine">Développé incliné</option>
                            <option value="Développé décliné|poitrine">Développé décliné</option>
                            <option value="Écarté poulie|poitrine">Écarté poulie</option>
                            <option value="Écarté haltères|poitrine">Écarté haltères</option>
                            <option value="Dips|poitrine">Dips</option>
                            <option value="Pompes|poitrine">Pompes</option>
                        </optgroup>
                        <optgroup label="Dos">
                            <option value="Tractions|dos">Tractions</option>
                            <option value="Rowing barre|dos">Rowing barre</option>
                            <option value="Rowing haltère|dos">Rowing haltère</option>
                            <option value="Tirage poitrine|dos">Tirage poitrine</option>
                            <option value="Tirage nuque|dos">Tirage nuque</option>
                            <option value="Soulevé de terre|dos">Soulevé de terre</option>
                            <option value="Pull-over|dos">Pull-over</option>
                        </optgroup>
                        <optgroup label="Jambes">
                            <option value="Squat barre|jambes">Squat barre</option>
                            <option value="Presse à cuisses|jambes">Presse à cuisses</option>
                            <option value="Fentes|jambes">Fentes</option>
                            <option value="Leg extension|jambes">Leg extension</option>
                            <option value="Leg curl|jambes">Leg curl</option>
                            <option value="Mollets debout|jambes">Mollets debout</option>
                            <option value="Hip thrust|jambes">Hip thrust</option>
                        </optgroup>
                        <optgroup label="Épaules">
                            <option value="Développé militaire|epaules">Développé militaire</option>
                            <option value="Élévations latérales|epaules">Élévations latérales</option>
                            <option value="Élévations frontales|epaules">Élévations frontales</option>
                            <option value="Oiseau|epaules">Oiseau (arrière)</option>
                            <option value="Arnold press|epaules">Arnold press</option>
                        </optgroup>
                        <optgroup label="Bras">
                            <option value="Curl barre|bras">Curl barre</option>
                            <option value="Curl haltères|bras">Curl haltères</option>
                            <option value="Curl marteau|bras">Curl marteau</option>
                            <option value="Extensions triceps poulie|bras">Extensions triceps poulie</option>
                            <option value="Barre au front|bras">Barre au front</option>
                            <option value="Kickback triceps|bras">Kickback triceps</option>
                            <option value="Dips triceps|bras">Dips triceps</option>
                        </optgroup>
                        <optgroup label="Abdos">
                            <option value="Crunch|abdos">Crunch</option>
                            <option value="Planche|abdos">Planche</option>
                            <option value="Relevé de jambes|abdos">Relevé de jambes</option>
                            <option value="Ab wheel|abdos">Ab wheel</option>
                            <option value="Russian twist|abdos">Russian twist</option>
                        </optgroup>
                        <optgroup label="Cardio">
                            <option value="Tapis de course|cardio">Tapis de course</option>
                            <option value="Vélo elliptique|cardio">Vélo elliptique</option>
                            <option value="Rameur|cardio">Rameur</option>
                            <option value="Burpees|cardio">Burpees</option>
                            <option value="Corde à sauter|cardio">Corde à sauter</option>
                        </optgroup>
                    </select>

                    <button onclick="addExercise()" class="bg-gradient-to-r from-cyan-500 to-blue-600 hover:brightness-110 text-white font-bold px-5 py-2 rounded-lg text-sm flex-shrink-0 flex items-center gap-2 transition-all shadow-[0_0_15px_rgba(6,182,212,0.3)]">
                        <i class="ph ph-plus-bold"></i> Ajouter
                    </button>
                    <button onclick="loadRecommendedSession()" title="Charger ma séance recommandée" class="bg-gradient-to-r from-violet-500 to-purple-600 hover:brightness-110 text-white font-bold px-4 py-2 rounded-lg text-sm flex-shrink-0 flex items-center gap-2 transition-all shadow-[0_0_15px_rgba(139,92,246,0.3)]">
                        Ajouter ma séance recommandée
                    </button>
                </div>

                <div class="glass rounded-2xl flex-1 flex flex-col overflow-hidden border-t-[3px] border-t-cyan-500 min-h-0">
                    <div class="flex justify-between items-center px-5 pt-4 pb-3 flex-shrink-0 border-b border-slate-700/30">
                        <h2 class="font-bold text-sm flex items-center gap-2">
                            Séance en cours
                        </h2>
                        <div class="flex items-center gap-3">
                            <span id="progressText" class="text-xs font-bold text-cyan-400 mono">0 série</span>
                            <div class="w-24 h-1.5 bg-slate-700 rounded-full overflow-hidden">
                                <div id="progressBar" class="bg-gradient-to-r from-cyan-400 to-blue-500 h-full rounded-full transition-all duration-500" style="width:0%"></div>
                            </div>
                        </div>
                    </div>
                    
                    <div id="exerciseList" class="px-4 py-3 space-y-3">
                        <div class="flex items-center justify-center py-12 text-slate-600">
                            <div class="animate-spin rounded-full h-7 w-7 border-b-2 border-cyan-500"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-4">

                <%
                let imc=null, imcLabel='—', imcColor='text-slate-300';
                if(user.profile.weight && user.profile.height){
                    imc = Math.round(user.profile.weight/Math.pow(user.profile.height/100,2)*10)/10;
                    if(imc<18.5){imcLabel='Sous-poids';imcColor='text-blue-400';}
                    else if(imc<25){imcLabel='Normal ✓';imcColor='text-green-400';}
                    else if(imc<30){imcLabel='Surpoids';imcColor='text-yellow-400';}
                    else{imcLabel='Obésité';imcColor='text-red-400';}
                }
                %>
                <div class="grid grid-cols-3 gap-3 flex-shrink-0">
                    <div class="glass rounded-xl p-3 text-center"><p class="text-[10px] text-slate-500 mono mb-1">IMC</p><p class="text-xl font-black <%= imcColor %>"><%= imc||'—' %></p><p class="text-[10px] text-slate-500"><%= imcLabel %></p></div>
                    <div class="glass rounded-xl p-3 text-center"><p class="text-[10px] text-slate-500 mono mb-1">SÉA/SEM</p><p class="text-xl font-black text-green-400"><%= user.profile.sessionsPerWeek %></p><p class="text-[10px] text-slate-500">objectif</p></div>
                    <div class="glass rounded-xl p-3 text-center"><p class="text-[10px] text-slate-500 mono mb-1">TOTAL</p><p class="text-xl font-black text-orange-400"><%= user.stats.totalExercises %></p><p class="text-[10px] text-slate-500">séries</p></div>
                </div>

                <div class="glass rounded-2xl p-4 flex-shrink-0">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <i class="ph ph-trend-up text-cyan-400"></i>
                            <span class="text-xs font-bold text-slate-200 mono uppercase tracking-wider">Progression</span>
                        </div>
                        <div class="flex gap-1 bg-slate-800/60 rounded-lg p-1">
                            <button onclick="switchChart('maxweight')" id="tab-maxweight" class="chart-tab active px-2 py-1 text-[10px] font-bold">Max kg</button>
                            <button onclick="switchChart('volume')"    id="tab-volume"    class="chart-tab        px-2 py-1 text-[10px]">Vol</button>
                            <button onclick="switchChart('tonnage')"   id="tab-tonnage"   class="chart-tab        px-2 py-1 text-[10px]">Tonnage</button>
                        </div>
                    </div>

                    <select id="chartExoSelect" class="exo-select w-full text-sm py-2 px-3 mb-3 font-bold"
                        onchange="renderChart(exercises, perfData)">
                        <option value="">— Choisir un exercice à analyser —</option>
                    </select>

                    <div class="grid grid-cols-3 gap-2 mb-3" id="chartKpis">
                        <div class="glass-dark rounded-xl px-2 py-2 text-center">
                            <p class="text-[9px] text-yellow-400 mono font-bold mb-0.5">🏆 RECORD</p>
                            <p class="text-sm font-black text-yellow-400" id="kpiPR">—</p>
                        </div>
                        <div class="glass-dark rounded-xl px-2 py-2 text-center">
                            <p class="text-[9px] text-slate-500 mono font-bold mb-0.5">DERNIÈRE</p>
                            <p class="text-sm font-black text-cyan-400" id="kpiLast">—</p>
                        </div>
                        <div class="glass-dark rounded-xl px-2 py-2 text-center">
                            <p class="text-[9px] text-slate-500 mono font-bold mb-0.5">TENDANCE</p>
                            <p class="text-sm font-black" id="kpiTrend">—</p>
                        </div>
                    </div>

                    <div class="h-28"><canvas id="evolutionChart"></canvas></div>
                    <p class="text-[10px] text-slate-600 text-center mt-1 mono" id="chartHint">Sélectionne un exercice pour voir sa progression</p>
                </div>

                <div class="glass rounded-2xl flex flex-col border-t-[3px] border-t-red-500">
                    <div class="px-4 py-3 border-b border-slate-700/40 flex justify-between items-center flex-shrink-0">
                        <h3 class="text-xs font-bold flex items-center gap-2"><i class="ph-fill ph-users text-red-500"></i> Zone d'entraide</h3>
                        <span class="flex items-center gap-1 text-[10px] font-bold text-emerald-400 bg-emerald-400/10 px-2 py-1 rounded-md mono">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> LIVE
                        </span>
                    </div>
                    
                    <div id="chatMessages" class="max-h-48 overflow-y-auto p-3 flex flex-col gap-2 text-xs"></div>
                    
                    <form id="chatForm" class="p-3 border-t border-slate-700/40 flex-shrink-0">
                        <div class="flex items-center gap-2">
                            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center text-[9px] font-black flex-shrink-0"><%= user.username.charAt(0).toUpperCase() %></div>
                            <input type="text" id="chatInput" autocomplete="off" placeholder="Motiver l'équipe..."
                                style="background:rgba(22,33,55,0.8);border:1px solid rgba(71,85,105,0.4);color:#e2e8f0;"
                                class="flex-1 rounded-lg px-3 py-2 text-xs outline-none">
                            <button type="submit" class="w-8 h-8 rounded-lg bg-red-500 hover:bg-red-600 text-white flex items-center justify-center flex-shrink-0">
                                <i class="ph-fill ph-paper-plane-right text-sm"></i>
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </main>

    <script>
   
    //  DONNÉES GLOBALES DE L'UTILISATEUR
   
    const USERNAME = '<%= user.username %>';
    let exercises = [];
    let perfData  = [];
    let myChart   = null;
    let currentTab = 'maxweight';

    const catColor = {
        poitrine:'text-rose-400 bg-rose-400/10 border-rose-400/20',
        dos:     'text-blue-400 bg-blue-400/10 border-blue-400/20',
        jambes:  'text-green-400 bg-green-400/10 border-green-400/20',
        epaules: 'text-purple-400 bg-purple-400/10 border-purple-400/20',
        bras:    'text-orange-400 bg-orange-400/10 border-orange-400/20',
        abdos:   'text-yellow-400 bg-yellow-400/10 border-yellow-400/20',
        cardio:  'text-cyan-400 bg-cyan-400/10 border-cyan-400/20',
        autre:   'text-slate-400 bg-slate-700/40 border-slate-600/30'
    };

    // DICTIONNAIRE DE SÉANCES RECOMMANDÉES
   
    const USER_GOAL  = '<%= user.profile.goal %>';
    const USER_LEVEL = '<%= user.profile.level %>';

    // Bibliothèque de séances selon : Objectif -> Niveau -> Liste d'exercices
    const SEANCES = {
        prise_de_masse: {
            debutant: [
                { name:'Développé couché',      category:'poitrine', sets:[{weight:40,reps:10},{weight:40,reps:10},{weight:40,reps:10}] },
                { name:'Tirage poitrine',        category:'dos',      sets:[{weight:35,reps:10},{weight:35,reps:10},{weight:35,reps:10}] },
                { name:'Développé militaire',    category:'epaules',  sets:[{weight:20,reps:10},{weight:20,reps:10},{weight:20,reps:10}] },
                { name:'Squat barre',            category:'jambes',   sets:[{weight:40,reps:10},{weight:40,reps:10},{weight:40,reps:10}] },
                { name:'Curl haltères',          category:'bras',     sets:[{weight:12,reps:12},{weight:12,reps:12},{weight:12,reps:12}] },
            ],
            intermediaire: [
                { name:'Développé couché',       category:'poitrine', sets:[{weight:70,reps:8},{weight:75,reps:6},{weight:80,reps:5},{weight:70,reps:8}] },
                { name:'Soulevé de terre',        category:'dos',      sets:[{weight:80,reps:6},{weight:90,reps:5},{weight:100,reps:4}] },
